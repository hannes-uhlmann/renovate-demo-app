{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
  "schedule": [
    "after 10pm",
    "before 6am"
  ],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 3,
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "groupName": "dev dependencies"
    },
    {
      "matchPackageNames": [
        "axios"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "enabled": true
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "non-major updates",
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
